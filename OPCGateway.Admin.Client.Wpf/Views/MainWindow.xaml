<Window x:Class="OPCGateway.Admin.Client.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:OPCGateway.Admin.Client.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="OPCGateway Admin"
        Height="720" Width="1280"
        MinHeight="600" MinWidth="900"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:ServerListViewModel}">
            <ContentControl Content="{Binding}" ContentTemplate="{StaticResource ServerListTemplate}"/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NodeListViewModel}">
            <ContentControl Content="{Binding}" ContentTemplate="{StaticResource NodeListTemplate}"/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NamespaceBrowserViewModel}">
            <ContentControl Content="{Binding}" ContentTemplate="{StaticResource NamespaceBrowserTemplate}"/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <ContentControl Content="{Binding}" ContentTemplate="{StaticResource SettingsTemplate}"/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Left navigation -->
        <Border Grid.Column="0" Grid.Row="0" Background="{DynamicResource NavBackgroundBrush}">
            <StackPanel Margin="0,16,0,0">
                <TextBlock Text="OPCGateway" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource NavHeaderForeground}"
                           Margin="16,0,0,24"/>

                <Button Style="{StaticResource NavButtonStyle}"
                        Command="{Binding NavigateToServersCommand}"
                        Content="🖧  Servers"/>

                <Button Style="{StaticResource NavButtonStyle}"
                        Command="{Binding NavigateToNodesCommand}"
                        Content="⬡  Managed Nodes"/>

                <Button Style="{StaticResource NavButtonStyle}"
                        Command="{Binding NavigateToSettingsCommand}"
                        Content="⚙  Settings"/>
            </StackPanel>
        </Border>

        <!-- Main content -->
        <ContentControl Grid.Column="1" Grid.Row="0"
                        Content="{Binding CurrentView}"
                        Margin="0"/>

        <!-- Status bar -->
        <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"
                Background="{DynamicResource StatusBarBrush}" Height="28">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                           VerticalAlignment="Center" Margin="12,0"
                           Foreground="{DynamicResource StatusBarForeground}"
                           FontSize="12"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            Margin="12,0" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#E74C3C"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="#2ECC71"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding ConnectionStatus}"
                               Foreground="{DynamicResource StatusBarForeground}"
                               FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
