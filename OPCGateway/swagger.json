              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKey": []
          }
        ]
      }
    },
    "/api/Connection/status/{connectionId}": {
      "get": {
        "tags": [
          "Connection"
        ],
        "parameters": [
          {
            "name": "connectionId",
            "in": "path",
            "required": true,
