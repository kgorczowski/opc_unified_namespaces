            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WriteMultipleDataRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/WriteMultipleDataRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/WriteMultipleDataRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AnonymousConnectionRequest": {
        "required": [
          "endpointUrl"
        ],
        "type": "object",
        "properties": {
          "endpointUrl": {
            "type": "string",
            "nullable": true
          },
          "securityMode": {
            "$ref": "#/components/schemas/SecurityMode"
          },
          "securityPolicy": {
            "$ref": "#/components/schemas/SecurityPolicy"
          }
        },
        "additionalProperties": false
      },
      "CertificateConnectionRequest": {
        "required": [
          "certificatePath",
          "endpointUrl"
        ],
        "type": "object",
        "properties": {
          "endpointUrl": {
            "type": "string",
            "nullable": true
          },
          "securityMode": {
            "$ref": "#/components/schemas/SecurityMode"
          },
          "securityPolicy": {
            "$ref": "#/components/schemas/SecurityPolicy"
          },
          "certificatePath": {
            "type": "string",
            "nullable": true
          },
          "certificatePassword": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "SecurityMode": {
        "enum": [
          "Auto",
          "None",
          "Sign",
          "SignAndEncrypt"
        ],
        "type": "string"
      },
      "SecurityPolicy": {
        "enum": [
          "Auto",
          "None",
          "Basic128Rsa15",
          "Basic256",
          "Basic256Sha256",
          "Aes128_Sha256_RsaOaep",
          "Aes256_Sha256_RsaPss"
        ],
        "type": "string"
      },
      "UserNameConnectionRequest": {
        "required": [
          "endpointUrl",
          "password",
          "username"
        ],
        "type": "object",
        "properties": {
          "endpointUrl": {
            "type": "string",
            "nullable": true
          },
          "securityMode": {
            "$ref": "#/components/schemas/SecurityMode"
          },
          "securityPolicy": {
            "$ref": "#/components/schemas/SecurityPolicy"
          },
          "username": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "WriteDataRequest": {
        "required": [
          "nodeId",
          "value",
          "valueType"
        ],
        "type": "object",
        "properties": {
          "nodeId": {
            "type": "string",
            "nullable": true
          },
          "value": {
            "nullable": true
          },
          "valueType": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "WriteDataValue": {
        "required": [
          "value",
          "valueType"
        ],
        "type": "object",
        "properties": {
          "valueType": {
            "type": "string",
            "nullable": true
          },
          "value": {
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "WriteMultipleDataRequest": {
        "required": [
          "nodeValues"
        ],
        "type": "object",
        "properties": {
          "nodeValues": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/WriteDataValue"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "ApiKey": {
        "type": "apiKey",
        "description": "API Key needed to access the endpoints. X-API-Key: {API Key}",
        "name": "X-API-Key",
        "in": "header"
      }
    }
  }
}