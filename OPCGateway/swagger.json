            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CertificateConnectionRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CertificateConnectionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          {
            "ApiKey": []
          }
        ]
      }
    },
    "/api/Connection/reconnect/{connectionId}": {
      "post": {
        "tags": [
          "Connection"
        ],
        "parameters": [
          {
            "name": "connectionId",
            "in": "path",
            "required": true,
