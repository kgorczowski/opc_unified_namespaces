    "/api/Data/writeMultiple/{connectionId}/{opcNamespace}": {
      "post": {
        "tags": [
          "Data"
        ],
        "parameters": [
          {
            "name": "connectionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "opcNamespace",
            "in": "path",
